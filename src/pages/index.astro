---
import { getCollection } from "astro:content";
import Footer from "../components/Footer.astro";
import LiveDispatchFeed from "../components/LiveDispatchFeed.astro";
import { ACTIVE_COLLECTION } from "../active-collection";
import { canonicalPageUrl, getNicheLabelForSeed, internalPath, siteConfig } from "../site-config";
import { REALTORS_AT_THE_BEACH_PLUMBING_V2 } from "../domain-templates/realtorsatthebeach.com-plumbing-v2";

const posts = await getCollection(ACTIVE_COLLECTION);
const pageNicheLabel = getNicheLabelForSeed("home");
const nicheLower = pageNicheLabel.toLowerCase();
const pageUrl = canonicalPageUrl();
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${pageNicheLabel} Service Pages`,
  description: `Browse all local ${nicheLower} service pages.`,
  url: pageUrl,
};
function entryPath(entry: { id?: string; slug?: string }) {
  const raw = entry.slug ?? entry.id ?? "";
  return raw.replace(/\.(md|mdx)$/i, "");
}
const sortedPosts = [...posts].sort((a, b) => entryPath(a).localeCompare(entryPath(b)));
function titleCase(input: string) {
  return input
    .split(/\s+/g)
    .filter(Boolean)
    .map((w) => w.slice(0, 1).toUpperCase() + w.slice(1))
    .join(" ");
}
function cityStateFromSlug(slugText: string): { city: string; state: string } | null {
  const m = slugText.match(/^(.*)-([a-z]{2})-(\d{5})$/i);
  if (!m) return null;
  const prefix = `${String(ACTIVE_COLLECTION)}-`.toLowerCase();
  let left = m[1] ?? "";
  if (left.toLowerCase().startsWith(prefix)) left = left.slice(prefix.length);
  return {
    city: titleCase(left.replace(/-/g, " ").trim()),
    state: m[2]!.toUpperCase(),
  };
}
function shuffled<T>(arr: T[]): T[] {
  const out = [...arr];
  for (let i = out.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [out[i], out[j]] = [out[j]!, out[i]!];
  }
  return out;
}
const dispatchRecords = shuffled(
  sortedPosts
    .map((post) => cityStateFromSlug(entryPath(post)))
    .filter((v): v is { city: string; state: string } => Boolean(v)),
)
  .slice(0, 8)
  .map((item, idx) => ({
    ...item,
    offset: 5 + Math.floor(Math.random() * 51),
    tag: (idx % 2 === 0 ? "[NODE ACTIVE]" : "[DISPATCH CONFIRMED]") as "[NODE ACTIVE]" | "[DISPATCH CONFIRMED]",
  }));

const featuredCities = [
  { city: "Los Angeles", state: "CA" },
  { city: "San Diego", state: "CA" },
  { city: "San Francisco", state: "CA" },
  { city: "San Jose", state: "CA" },
  { city: "Seattle", state: "WA" },
  { city: "Boston", state: "MA" },
  { city: "Miami", state: "FL" },
  { city: "Washington", state: "DC" },
  { city: "Honolulu", state: "HI" },
  { city: "Jersey City", state: "NJ" },
];
function normalizeSlugPart(value: string) {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
}
const featuredHubs = featuredCities
  .map((item) => {
    const cityKey = normalizeSlugPart(item.city);
    const stateKey = item.state.toLowerCase();
    const directSlug = `${String(ACTIVE_COLLECTION)}-${cityKey}-${stateKey}`;
    const byPrefix = sortedPosts.find((p) => entryPath(p).startsWith(`${directSlug}-`));
    if (!byPrefix) return null;
    return {
      label: `${item.city}, ${item.state}`,
      href: internalPath(entryPath(byPrefix)),
    };
  })
  .filter((item): item is { label: string; href: string } => Boolean(item));
const themeAccent = ACTIVE_COLLECTION === "plumbing-v2"
  ? REALTORS_AT_THE_BEACH_PLUMBING_V2.theme.accent
  : "#1d4ed8";
---

<html lang="en" style={`--theme-accent:${themeAccent};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="e8639489520c639b" />
    <title>{pageNicheLabel} Service Pages</title>
    <meta
      name="description"
      content={`Browse all local ${nicheLower} service pages.`}
    />
    <meta name="robots" content={siteConfig.robotsContent} />
    <link rel="canonical" href={pageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <style>
      :root {
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      body {
        margin: 0;
        background: #f8fafc;
        color: #0f172a;
      }
      main {
        width: min(980px, 94vw);
        margin: 2rem auto;
        background: #fff;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 8px 26px rgba(2, 6, 23, 0.08);
      }
      h1 {
        margin: 0 0 0.4rem;
      }
      .meta {
        color: #475569;
        margin-bottom: 1rem;
      }
      .tunnel {
        margin: 1rem 0 1.25rem;
      }
      .tunnel-btn {
        display: inline-block;
        padding: 0.65rem 1rem;
        border: 2px solid var(--theme-accent, #1d4ed8);
        border-radius: 10px;
        font-weight: 700;
        background: #eff6ff;
      }
      .featured-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.45rem 1rem;
        padding-left: 1.1rem;
      }
      a {
        color: var(--theme-accent, #1d4ed8);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      @media (max-width: 900px) {
        .featured-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <h1>All {pageNicheLabel} Pages</h1>
      <p class="meta">Total pages: {sortedPosts.length}</p>
      <p class="meta">Hub tunnel mode: centralized entry with weighted deep links.</p>
      <div class="tunnel">
        <a class="tunnel-btn" href={internalPath("national-service-coverage")}>
          [+] View All U.S. Service Locations
        </a>
      </div>

      <h2>Featured Hubs</h2>
      <p class="meta">Direct authority links to priority city nodes.</p>
      <ul class="featured-grid">
        {featuredHubs.map((hub) => (
          <li>
            <a href={hub.href}>{pageNicheLabel} in {hub.label}</a>
          </li>
        ))}
      </ul>
      <LiveDispatchFeed records={dispatchRecords} />
    </main>
    <Footer />
  </body>
</html>
