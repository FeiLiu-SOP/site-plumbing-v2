---
import { getCollection, render } from "astro:content";
import Footer from "../components/Footer.astro";
import RelatedCities from "../components/RelatedCities.astro";
import { ACTIVE_COLLECTION } from "../active-collection";
import { canonicalPageUrl, internalPath, siteConfig } from "../site-config";
import {
  buildFaqSchema,
  buildLocalBusinessSchema,
  getFaqByCollection,
} from "../lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection(ACTIVE_COLLECTION);
  return posts.map((post) => ({
    params: { slug: (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "") },
  }));
}

const { slug } = Astro.params;
const posts = await getCollection(ACTIVE_COLLECTION);
const entrySlugParam = (slug ?? "").replace(/\.(md|mdx)$/i, "");
const entry =
  posts.find((p) => (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "") === entrySlugParam) ?? null;
if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
const { Content } = await render(entry);
const post = entry;
const entrySlug = entrySlugParam || (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "");
const pageUrl = canonicalPageUrl(entrySlug);
const stateCodeFromSlug = (() => {
  const m = entrySlug.match(/-([a-z]{2})-\d{5}$/i);
  return m ? m[1]!.toUpperCase() : null;
})();

// Action 1: footer random internal link from backup pool (state index + random city)
const backupCandidates: { href: string; label: string }[] = [];
if (stateCodeFromSlug) {
  backupCandidates.push({
    href: internalPath(stateCodeFromSlug.toLowerCase()),
    label: `Browse ${siteConfig.nicheLabel} in ${stateCodeFromSlug}`,
  });
}
const other = posts.filter((p) => (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "") !== entrySlug);
if (other.length > 0) {
  const pick = other[Math.floor(Math.random() * other.length)]!;
  const pickSlug = (pick.slug ?? pick.id ?? "").replace(/\.(md|mdx)$/i, "");
  backupCandidates.push({
    href: internalPath(pickSlug),
    label: `Another ${siteConfig.nicheLabel} page`,
  });
}
const footerExtraLink =
  backupCandidates.length > 0 ? backupCandidates[Math.floor(Math.random() * backupCandidates.length)]! : null;
const faqItems = getFaqByCollection(ACTIVE_COLLECTION);
function stableHash(input: string) {
  let h = 2166136261;
  for (let i = 0; i < input.length; i++) {
    h ^= input.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function pickFaqSubset<T>(items: T[], seedText: string, count: number): T[] {
  const copy = [...items];
  let seed = stableHash(seedText);
  for (let i = copy.length - 1; i > 0; i--) {
    seed = Math.imul(seed ^ (seed >>> 13), 1274126177) >>> 0;
    const j = seed % (i + 1);
    const a = copy[i]!;
    const b = copy[j]!;
    copy[i] = b;
    copy[j] = a;
  }
  return copy.slice(0, Math.min(count, copy.length));
}
const faqCount = 3 + (stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|faqCount`) % 3); // 3–5
const pageFaqItems = pickFaqSubset(faqItems, `${ACTIVE_COLLECTION}|${entrySlug}|faq`, faqCount);
const ctaVariants = [
  {
    title: `24/7 Local ${siteConfig.nicheLabel} Emergency Service`,
    meta: "Fast dispatch, transparent pricing, and free inspection availability.",
  },
  {
    title: `Same-Day ${siteConfig.nicheLabel} Support Options`,
    meta: "Rapid scheduling windows, scope review, and straightforward next-step guidance.",
  },
  {
    title: `Local ${siteConfig.nicheLabel} Dispatch and Response`,
    meta: "Clear intake, practical timing expectations, and direct call routing.",
  },
  {
    title: `${siteConfig.nicheLabel} Help for Urgent Property Issues`,
    meta: "Quick coordination, service planning, and transparent appointment communication.",
  },
  {
    title: `On-Demand ${siteConfig.nicheLabel} Service Availability`,
    meta: "Responsive local coverage with call-first scheduling and pricing clarity.",
  },
];
const ctaVariant = ctaVariants[stableHash(`${entrySlug}|cta`) % ctaVariants.length]!;
const serviceLineVariants = [
  `Licensed local technicians available for urgent ${siteConfig.nicheLabel.toLowerCase()} service calls and rapid response.`,
  `Certified dispatch coverage for time-sensitive ${siteConfig.nicheLabel.toLowerCase()} requests and urgent property issues.`,
  `Qualified local routing for priority ${siteConfig.nicheLabel.toLowerCase()} calls with clear intake verification.`,
  `Insured scheduling support for urgent ${siteConfig.nicheLabel.toLowerCase()} service needs and same-day windows where available.`,
  `Local service coordination for ${siteConfig.nicheLabel.toLowerCase()} requests with practical timelines and scope clarity.`,
];
const serviceLine =
  serviceLineVariants[stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|svcLine`) % serviceLineVariants.length]!;
const callBtnVariants = [
  `Call now: ${siteConfig.phoneDisplay}`,
  `Tap to call: ${siteConfig.phoneDisplay}`,
  `Request service: ${siteConfig.phoneDisplay}`,
  `Call for scheduling: ${siteConfig.phoneDisplay}`,
  `Phone support: ${siteConfig.phoneDisplay}`,
];
const callBtnLabel =
  callBtnVariants[stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|callBtn`) % callBtnVariants.length]!;
const headerVariants = [
  `National ${siteConfig.nicheLabel} Intake & Dispatch`,
  `${siteConfig.nicheLabel} Service Routing Network`,
  `Local ${siteConfig.nicheLabel} Coverage Coordination`,
  `${siteConfig.nicheLabel} Scheduling & Response Hub`,
  `Regional ${siteConfig.nicheLabel} Service Access Point`,
];
const headerVariant = headerVariants[stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|header`) % headerVariants.length]!;
const faqTitleVariants = [
  "Frequently Asked Questions",
  "Service Questions and Answers",
  "Common Scheduling Questions",
  "Quick FAQ",
  "Help Center: FAQ",
] as const;
const faqTitle = faqTitleVariants[stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|faqTitle`) % faqTitleVariants.length]!;
const stateNotice = stateCodeFromSlug
  ? `Notice: This ${stateCodeFromSlug} service node is optimized for local topographic and seasonal conditions.`
  : "Notice: This service node is optimized for local topographic and seasonal conditions.";
const telHref = `tel:${siteConfig.phoneE164.replace(/^\+/, "")}`;

// Action 3: Geo brief section data from frontmatter (truthy only; Astro just displays)
const geo = {
  county: post.data.county as string | undefined,
  elevationFt: typeof post.data.elevationFt === "number" ? post.data.elevationFt : undefined,
  lat: typeof post.data.lat === "number" ? post.data.lat : undefined,
  lng: typeof post.data.lng === "number" ? post.data.lng : undefined,
  zipSample: Array.isArray(post.data.zipSample) ? post.data.zipSample : undefined,
  zipCodes: Array.isArray(post.data.zipCodes) ? post.data.zipCodes : undefined,
  localPaths: Array.isArray(post.data.localPaths) ? post.data.localPaths : undefined,
};
const geoBriefText =
  geo.county && typeof geo.lat === "number" && typeof geo.lng === "number"
    ? [
        `Regional Infrastructure Brief: County ${geo.county}. Coordinates: ${geo.lat.toFixed(4)}, ${geo.lng.toFixed(
          4,
        )}. ZIP sample: ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.`,
        `Regional Infrastructure Brief: Serving ${geo.county}. Coordinate anchor: ${geo.lat.toFixed(
          4,
        )}, ${geo.lng.toFixed(4)}. ZIP sectors: ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.`,
        `Regional Infrastructure Brief: ${geo.county} coverage node. Coordinates ${geo.lat.toFixed(
          4,
        )}, ${geo.lng.toFixed(4)}. Sample ZIPs: ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.`,
        `Regional Infrastructure Brief: County grid ${geo.county}. Lat/Lng: ${geo.lat.toFixed(4)}, ${geo.lng.toFixed(
          4,
        )}. ZIP sample set: ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.`,
        `Regional Infrastructure Brief: ${geo.county} dispatch context. Coordinates ${geo.lat.toFixed(
          4,
        )}, ${geo.lng.toFixed(4)}. ZIP sample: ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.`,
      ][stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|geoBrief`) % 5]
    : null;
const localPathsText =
  geo.localPaths && geo.localPaths.length
    ? [
        `Logistics optimization for ${geo.localPaths.slice(0, 5).join(", ")} transit sectors.`,
        `Routing optimization focuses on ${geo.localPaths.slice(0, 5).join(", ")} corridors.`,
        `Dispatch routing notes reference ${geo.localPaths.slice(0, 5).join(", ")} sectors.`,
        `Transit optimization markers: ${geo.localPaths.slice(0, 5).join(", ")}.`,
        `Coverage routing hints: ${geo.localPaths.slice(0, 5).join(", ")}.`,
      ][stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|pathsLine`) % 5]
    : null;

function addendumForFaq(seedText: string) {
  const pool = [
    geo.county ? `Local note: County context — ${geo.county}.` : null,
    geo.zipSample?.length ? `Local note: Sample ZIP sectors — ${(geo.zipSample ?? []).slice(0, 5).join(", ")}.` : null,
    stateCodeFromSlug ? `Local note: State routing node — ${stateCodeFromSlug}.` : null,
    typeof geo.lat === "number" && typeof geo.lng === "number"
      ? `Local note: Coordinate anchor — ${geo.lat.toFixed(4)}, ${geo.lng.toFixed(4)}.`
      : null,
    geo.localPaths?.length ? `Local note: Transit markers — ${(geo.localPaths ?? []).slice(0, 2).join("; ")}.` : null,
  ].filter(Boolean) as string[];
  if (!pool.length) return null;
  return stableHash(seedText) % 2 === 0 ? pool[stableHash(seedText + "|p") % pool.length]! : null;
}

const pageFaqItemsFinal = pageFaqItems.map((item, idx) => {
  const add = addendumForFaq(`${ACTIVE_COLLECTION}|${entrySlug}|faqAdd|${idx}`);
  return {
    question: item.question,
    answer: add ? `${item.answer} ${add}` : item.answer,
  };
});

const localBusinessSchema = buildLocalBusinessSchema({
  collection: ACTIVE_COLLECTION,
  pageTitle: post.data.title,
  pageDescription: post.data.description,
  pageUrl,
  location: null,
});
const faqSchema = buildFaqSchema(pageFaqItemsFinal);

// Action 3: stable DOM section randomizer for 4 blocks (content / geo / faq / related)
const orderSeed = stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|order`);
const blocks = ["content", "geo", "faq", "related"] as const;
const blockOrder = [...blocks];
{
  let s = orderSeed;
  for (let i = blockOrder.length - 1; i > 0; i--) {
    s = Math.imul(s ^ (s >>> 13), 1274126177) >>> 0;
    const j = s % (i + 1);
    const a = blockOrder[i]!;
    const b = blockOrder[j]!;
    blockOrder[i] = b;
    blockOrder[j] = a;
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="e8639489520c639b" />
    <title>{post.data.title}</title>
    <meta name="description" content={post.data.description} />
    <meta name="robots" content={siteConfig.robotsContent} />
    {post.data.templateVersion ? (
      <meta name="template-version" content={post.data.templateVersion} />
    ) : null}
    <link rel="canonical" href={pageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      body {
        margin: 0;
        background: #f8fafc;
        color: #0f172a;
      }
      main {
        width: min(800px, 92vw);
        margin: 2rem auto;
        background: #fff;
        border-radius: 12px;
        padding: 2rem 1.25rem;
        box-shadow: 0 8px 30px rgba(2, 6, 23, 0.08);
      }
      h1 {
        line-height: 1.2;
        margin-top: 0;
      }
      .service-info {
        margin: 1.5rem 0 2rem;
        padding: 1.25rem 1.4rem;
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        border: 1px solid #cbd5e1;
        border-left: 6px solid #0f172a;
        border-radius: 10px;
      }
      .service-info h2 {
        margin: 0 0 0.5rem;
        font-size: 1.25rem;
      }
      .service-info p {
        margin: 0.25rem 0;
        color: #334155;
      }
      .service-meta {
        font-size: 0.95rem;
      }
      .phone-btn {
        display: inline-block;
        margin-top: 0.8rem;
        background: #dc2626;
        color: #fff;
        padding: 0.7rem 1rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
      }
      .phone-btn:hover {
        background: #b91c1c;
      }
      .faq {
        margin-top: 2rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1rem;
      }
      .faq h2 {
        margin: 0 0 0.75rem;
      }
      .faq details {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #f8fafc;
        margin-bottom: 0.6rem;
        padding: 0.6rem 0.8rem;
      }
      .faq summary {
        cursor: pointer;
        font-weight: 600;
      }
      .faq p {
        margin: 0.55rem 0 0.1rem;
        color: #334155;
      }
      .geo-brief {
        margin-top: 1.75rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1rem;
      }
      .geo-brief h2 {
        margin: 0 0 0.5rem;
      }
      .geo-brief p {
        margin: 0.4rem 0;
        color: #334155;
      }
    </style>
    <!-- Markdown 由 <Content /> 注入，子节点无本页 scoped 属性；用 is:global + 固定 id，避免 dev/HMR 下偶发“正文像空白”（与 build 静态 HTML 一致） -->
    <style is:global>
      #article-md-body {
        max-width: 100%;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      /* Engineering Notice: always first paragraph emitted by generator */
      #article-md-body p:first-child {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
          monospace;
        font-size: 0.92rem;
        line-height: 1.45;
        background: #0b1220;
        color: #e2e8f0;
        border: 1px solid rgba(226, 232, 240, 0.18);
        border-radius: 10px;
        padding: 0.75rem 0.9rem;
        margin: 0 0 1rem;
      }
      #article-md-body p:first-child strong {
        color: #f8fafc;
        font-weight: 700;
      }
      #article-md-body p {
        display: block;
        margin: 0.65rem 0;
        color: #334155;
        line-height: 1.55;
      }
      #article-md-body strong {
        color: #0f172a;
      }
    </style>
  </head>
  <body>
    <main>
      <article>
        <h1>{post.data.title}</h1>
        <p style="margin: 0.25rem 0 0; color: #475569; font-size: 0.98rem;">
          {headerVariant}
        </p>
        <div class="service-info">
          <h2>{ctaVariant.title}</h2>
          <p>{serviceLine}</p>
          <p class="service-meta">{ctaVariant.meta}</p>
          <a class="phone-btn" href={telHref}>
            {callBtnLabel}
          </a>
        </div>
        {
          blockOrder.map((k) => {
            if (k === "content") {
              return (
                <div id="article-md-body" class="article-content">
                  <Content />
                </div>
              );
            }
            if (k === "geo") {
              return geoBriefText ? (
                <section class="geo-brief" aria-labelledby="geo-brief-title">
                  <h2 id="geo-brief-title">Regional Infrastructure Brief</h2>
                  <p>{geoBriefText}</p>
                  {localPathsText ? <p>{localPathsText}</p> : null}
                  {geo.elevationFt ? (
                    <p>
                      Elevation context: {geo.elevationFt} ft (reference band).
                    </p>
                  ) : null}
                  {geo.zipCodes?.length ? (
                    <div>
                      <p style="margin-bottom: 0.25rem;">ZIP coverage snapshot (sampled):</p>
                      <details>
                        <summary style="cursor: pointer; font-weight: 600;">
                          View ZIP list ({geo.zipCodes.slice(0, 12).length})
                        </summary>
                        <ul style="margin: 0.55rem 0 0; padding-left: 1.25rem;">
                          {geo.zipCodes.slice(0, 12).map((z) => (
                            <li>{z}</li>
                          ))}
                        </ul>
                      </details>
                    </div>
                  ) : null}
                  {geo.localPaths?.length ? (
                    <div style="margin-top: 0.65rem;">
                      <p style="margin-bottom: 0.25rem;">Transit markers:</p>
                      <details>
                        <summary style="cursor: pointer; font-weight: 600;">
                          View transit markers ({geo.localPaths.slice(0, 5).length})
                        </summary>
                        <ul style="margin: 0.55rem 0 0; padding-left: 1.25rem;">
                          {geo.localPaths.slice(0, 5).map((p) => (
                            <li>{p}</li>
                          ))}
                        </ul>
                      </details>
                    </div>
                  ) : null}
                </section>
              ) : null;
            }
            if (k === "faq") {
              return (
                <section class="faq" aria-labelledby="faq-title">
                  <h2 id="faq-title">{faqTitle}</h2>
                  {pageFaqItemsFinal.map((item) => (
                    <details>
                      <summary>{item.question}</summary>
                      <p>{item.answer}</p>
                    </details>
                  ))}
                </section>
              );
            }
            return <RelatedCities currentSlug={entrySlug} state={stateCodeFromSlug} />;
          })
        }
      </article>
    </main>
    <Footer
      extraLink={footerExtraLink}
      notice={stateNotice}
      variantSeed={`${ACTIVE_COLLECTION}|${entrySlug}|footer`}
    />
  </body>
</html>
